# Terraform state files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Terraform variable files (contain credentials)
*.tfvars
!*.tfvars.example

# Terraform directories
.terraform/

# Lock files are platform-dependent (checksums vary by OS/arch).
# They should be generated locally via `terraform init` during deployment,
# not committed with fabricated hashes.
.terraform.lock.hcl

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config
.terraformrc
terraform.rc
