{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ocr-local.dev/schemas/output_manifest.schema.json",
  "title": "Output Manifest",
  "description": "Manifest file listing all output artifacts produced for a single document. Provides a single index for downstream consumers to discover all sidecar files.",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Schema version for this output format."
    },
    "document_id": {
      "type": "string",
      "description": "Unique document identifier."
    },
    "source_file": {
      "type": "string",
      "description": "Source document filename."
    },
    "pipeline_version": {
      "type": "string",
      "description": "Pipeline version string."
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of manifest generation."
    },
    "artifacts": {
      "type": "array",
      "description": "List of output artifacts produced.",
      "items": {
        "type": "object",
        "properties": {
          "output_type": {
            "type": "string",
            "description": "One of the defined OUTPUT_TYPES."
          },
          "path": {
            "type": "string",
            "description": "Relative path to the artifact file."
          },
          "sha256": {
            "type": "string",
            "description": "SHA-256 hash of the artifact file for integrity verification."
          },
          "size_bytes": {
            "type": "integer",
            "description": "File size in bytes."
          },
          "mime_type": {
            "type": "string",
            "description": "MIME type of the artifact."
          }
        },
        "required": ["output_type", "path"]
      }
    },
    "processing_summary": {
      "type": "object",
      "description": "Summary of what processing was performed.",
      "properties": {
        "ocr_performed": { "type": "boolean" },
        "docintel_enabled": { "type": "boolean" },
        "ner_enabled": { "type": "boolean" },
        "extraction_enabled": { "type": "boolean" },
        "classification_enabled": { "type": "boolean" },
        "handwriting_detection_enabled": { "type": "boolean" },
        "signature_verification_enabled": { "type": "boolean" },
        "vertical_text_enabled": { "type": "boolean" },
        "entity_consolidation_enabled": { "type": "boolean" }
      }
    }
  },
  "required": ["schema_version", "document_id", "source_file", "pipeline_version", "generated_at", "artifacts"]
}
