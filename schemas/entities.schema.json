{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ocr-local.dev/schemas/entities.schema.json",
  "title": "Consolidated Entity Output",
  "description": "Unified entity sidecar merging NER, extraction, and classification results. Written to EXPORT/ENTITIES/<subfolder>/<document_name>.entities.json.",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Schema version for this output format."
    },
    "document": {
      "type": "string",
      "description": "Source document filename."
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of generation."
    },
    "pipeline_version": {
      "type": "string",
      "description": "Pipeline version string."
    },
    "entities": {
      "type": "array",
      "description": "Deduplicated entities from NER, extraction, and classification sources.",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Entity identifier (e.g. ent_001, ner_001, ext_001)."
          },
          "type": {
            "type": "string",
            "description": "Entity type (PERSON, DATE, amount, reference_number, etc.)."
          },
          "text": {
            "type": "string",
            "description": "Extracted text content."
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "Detection confidence score."
          },
          "source": {
            "type": "string",
            "enum": ["ner", "extraction", "classification"],
            "description": "Source module that produced this entity."
          },
          "page": {
            "type": "integer",
            "description": "Page number where entity was found."
          },
          "bbox": {
            "type": "array",
            "items": { "type": "number" },
            "description": "Bounding box coordinates (may be empty)."
          },
          "metadata": {
            "type": "object",
            "description": "Source-specific metadata (start/end offsets, extraction method, etc.)."
          }
        },
        "required": ["id", "type", "text", "confidence", "source", "page"]
      }
    },
    "classifications": {
      "type": "array",
      "description": "Document classification labels.",
      "items": {
        "type": "object",
        "properties": {
          "label": { "type": "string", "description": "Classification label." },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "method": { "type": "string", "description": "Classification method (e.g. ensemble)." }
        },
        "required": ["label", "confidence", "method"]
      }
    },
    "key_value_pairs": {
      "type": "array",
      "description": "Key-value pairs from extraction or NER.",
      "items": {
        "type": "object",
        "properties": {
          "key": { "type": "string" },
          "value": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "page": { "type": "integer" },
          "source": { "type": "string" }
        },
        "required": ["key", "value", "confidence", "page", "source"]
      }
    },
    "summary": {
      "type": "object",
      "description": "Aggregate entity statistics.",
      "properties": {
        "total_entities": { "type": "integer" },
        "entity_types": { "type": "object", "description": "Counts per entity type." },
        "total_kv_pairs": { "type": "integer" },
        "primary_classification": { "type": "string" }
      },
      "required": ["total_entities", "entity_types", "total_kv_pairs", "primary_classification"]
    }
  },
  "required": ["schema_version", "document", "generated_at", "pipeline_version", "entities", "classifications", "key_value_pairs", "summary"]
}
