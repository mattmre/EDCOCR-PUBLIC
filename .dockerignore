# =============================================================================
# .dockerignore - Root build context
# =============================================================================
# Applies to: Dockerfile (root), coordinator/Dockerfile.worker*,
# coordinator/Dockerfile.worker.ocr, coordinator/Dockerfile.worker.nlp,
# coordinator/Dockerfile.worker.layoutlm
#
# The root Dockerfile uses explicit COPY per file, so exclusions here mainly
# reduce build-context transfer size.  The worker Dockerfiles use COPY . /app/
# so exclusions here directly prevent bloat and sensitive data from entering
# production images.
# =============================================================================

# -- Version control ----------------------------------------------------------
.git/
.gitignore
.gitattributes

# -- CI / GitHub --------------------------------------------------------------
.github/

# -- Tests --------------------------------------------------------------------
tests/
pytest.ini
.coverage
coverage.xml
htmlcov/
conftest.py

# -- Documentation ------------------------------------------------------------
docs/
*.md
!README.md

# -- AI assistant config ------------------------------------------------------
.ai-assistant/

# -- Windows launchers --------------------------------------------------------
*.bat

# -- Local runtime artifacts --------------------------------------------------
ocr_output/
ocr_temp/
ocr_source/
*.log
*.pyc
__pycache__/
.pytest_cache/
.ruff_cache/
tmp/

# -- Deployment & infrastructure (not needed inside containers) ---------------
helm/
terraform/
playwright/
playwright-artifacts/
playwright.config.js
legacy/

# -- Development tooling ------------------------------------------------------
scripts/
sdk/
benchmark_results/

# -- Node / dashboard (separate build context) --------------------------------
node_modules/
package.json
package-lock.json
dashboard/

# -- Editor / IDE -------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo

# -- Secrets / environment ----------------------------------------------------
.env
coordinator/.env

# -- Stale implementation-note text files (not production code) ----------------
