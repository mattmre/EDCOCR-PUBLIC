# EDCOCR frontend environment contract
# Copy to .env.local for local development.

# Base URL of the FastAPI backend. The frontend appends /api/v1/* paths to this.
# In production this is typically the cluster-internal Service or the Ingress
# host (e.g. https://api.ocr.example.com).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
