# Coordinator Configuration
# REQUIRED: Override in production -- generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,coordinator.example.com
DEPLOYMENT_ENV=staging
PRODUCTION_READINESS_ACK=false

# Database
# REQUIRED: Override in production
POSTGRES_PASSWORD=change-me-to-a-strong-password

# Message Broker
RABBITMQ_USER=ocr_user
# REQUIRED: Override in production
RABBITMQ_PASSWORD=change-me-to-a-strong-password
# Required only for HA overlay (docker-compose.ha.yml) -- must be identical across all RabbitMQ nodes
RABBITMQ_ERLANG_COOKIE=change-me-in-production
# REQUIRED: Override in production
REDIS_PASSWORD=change-me-to-a-strong-password
FLOWER_USER=admin
# REQUIRED: Override in production
FLOWER_PASSWORD=change-me-to-a-strong-password

# Shared Filesystem
NFS_ROOT=/shared

# Local MinIO / S3 storage credentials
# REQUIRED: Override in production -- do NOT use default MinIO credentials (minioadmin)
MINIO_ROOT_USER=change-me-to-a-minio-access-key
MINIO_ROOT_PASSWORD=change-me-to-a-minio-secret-key
S3_ENDPOINT=http://minio:9000
S3_BUCKET=ocr-local
# REQUIRED: Override in production -- must match MINIO_ROOT_USER/PASSWORD or use IAM role
S3_ACCESS_KEY=change-me-to-a-minio-access-key
S3_SECRET_KEY=change-me-to-a-minio-secret-key
S3_REGION=us-east-1

# Worker Configuration (for worker nodes)
# REQUIRED: Override in production -- embed real credentials in the URLs
CELERY_BROKER_URL=amqp://ocr_user:password@coordinator-host:5672//
CELERY_RESULT_BACKEND=redis://coordinator-host:6379/0
DATABASE_URL=postgres://ocr:password@coordinator-host:5432/ocr_coordinator
JOB_PROCESSING_TIMEOUT_MINUTES=30
WORKER_QUEUES=ocr_gpu,cpu_general
WORKER_CONCURRENCY=4

# Metrics / Monitoring
# REQUIRED: Override in production -- used for /api/v1/metrics/ and /api/v1/prometheus/ auth
METRICS_API_KEY=change-me-to-a-metrics-api-key
