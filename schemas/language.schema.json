{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ocr-local.dev/schemas/language.schema.json",
  "title": "Per-Span Language Detection Output",
  "description": "Per-span language detection sidecar with script family, BCP-47 language codes, and per-page/per-document aggregates.  Written to EXPORT/LANGUAGE/<subfolder>/<document_name>.language.json.",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Schema version for this output format."
    },
    "document_id": {
      "type": "string",
      "description": "Unique document identifier."
    },
    "source_file": {
      "type": "string",
      "description": "Source document filename."
    },
    "processing": {
      "type": "object",
      "description": "Detection engine metadata and model provenance.",
      "properties": {
        "detection_engine": {
          "type": "string",
          "description": "Detection engines used, joined by '+' (e.g. fasttext+script_heuristic)."
        },
        "detector_model_sha256": {
          "type": "string",
          "description": "SHA-256 of the primary detector model artifact."
        },
        "tokenizer_sha256": {
          "type": "string",
          "description": "SHA-256 of the tokenizer used for span preprocessing."
        },
        "fasttext_model_sha256": {
          "type": "string",
          "description": "SHA-256 of the FastText lid.176.bin model artifact."
        },
        "pipeline_version": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": [
        "detection_engine",
        "detector_model_sha256",
        "tokenizer_sha256",
        "fasttext_model_sha256",
        "pipeline_version",
        "timestamp"
      ]
    },
    "document_summary": {
      "type": "object",
      "description": "Document-level language summary.",
      "properties": {
        "primary_language": {
          "type": "string",
          "description": "Dominant language by weighted character count, or 'und'."
        },
        "primary_confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "languages_detected": {
          "type": "array",
          "items": { "type": "string" }
        },
        "language_char_shares": {
          "type": "object",
          "additionalProperties": { "type": "number", "minimum": 0, "maximum": 1 }
        },
        "page_count": { "type": "integer", "minimum": 0 },
        "pages_with_mixed_script": { "type": "integer", "minimum": 0 }
      },
      "required": [
        "primary_language",
        "primary_confidence",
        "languages_detected",
        "language_char_shares",
        "page_count",
        "pages_with_mixed_script"
      ]
    },
    "pages": {
      "type": "array",
      "description": "Per-page language analysis.",
      "items": {
        "type": "object",
        "properties": {
          "page_num": { "type": "integer", "minimum": 1 },
          "primary_language": { "type": "string" },
          "primary_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "languages_detected": {
            "type": "array",
            "items": { "type": "string" }
          },
          "language_char_shares": {
            "type": "object",
            "additionalProperties": { "type": "number", "minimum": 0, "maximum": 1 }
          },
          "scripts_detected": {
            "type": "array",
            "items": { "type": "string" }
          },
          "mixed_script": { "type": "boolean" },
          "span_count": { "type": "integer", "minimum": 0 },
          "spans_labeled": { "type": "integer", "minimum": 0 },
          "spans": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "bbox": {
                  "type": "array",
                  "items": { "type": "number" },
                  "minItems": 4,
                  "maxItems": 4
                },
                "text_sample": { "type": "string" },
                "language": { "type": "string" },
                "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
                "script": { "type": "string" },
                "detection_method": {
                  "type": "string",
                  "description": "Detection method: fasttext, script_heuristic, or inherited_page."
                },
                "char_count": { "type": "integer", "minimum": 0 }
              },
              "required": [
                "bbox",
                "text_sample",
                "language",
                "confidence",
                "script",
                "detection_method",
                "char_count"
              ]
            }
          }
        },
        "required": [
          "page_num",
          "primary_language",
          "primary_confidence",
          "languages_detected",
          "language_char_shares",
          "scripts_detected",
          "mixed_script",
          "span_count",
          "spans_labeled",
          "spans"
        ]
      }
    }
  },
  "required": [
    "schema_version",
    "document_id",
    "source_file",
    "processing",
    "document_summary",
    "pages"
  ]
}
